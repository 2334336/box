<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_dialog_bg_main"
        android:orientation="horizontal"
        android:padding="@dimen/vs_30">

        <ImageView
            android:id="@+id/ivQRCode"
            android:layout_width="@dimen/vs_300"
            android:layout_height="@dimen/vs_300"
            android:layout_gravity="center"
            android:focusable="false" />

        <LinearLayout
            android:layout_width="@dimen/vs_480"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="@dimen/vs_20"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/color_CC000000"
                android:textSize="@dimen/ts_22"
                tools:text="手机/电脑扫描上方二维码或者直接浏览器访问地址" />

            <EditText
                android:id="@+id/inputStoreApiUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_20"
                android:background="@drawable/input_dialog_api_input"
                android:hint="请输入多源/多仓地址"
                android:imeOptions="actionDone"
                android:inputType="textUri"
                android:maxLines="3"
                android:minLines="1"
                android:paddingLeft="@dimen/vs_10"
                android:paddingTop="@dimen/vs_10"
                android:paddingRight="@dimen/vs_10"
                android:paddingBottom="@dimen/vs_10"
                android:textColor="@color/color_CC000000"
                android:textColorHint="@color/color_6C3D3D3D"
                android:textSize="@dimen/ts_24" />

            <!-- 订阅状态：加载中 / 成功 / 失败，避免空白区域看不出状态 -->
            <TextView
                android:id="@+id/tvStoreApiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_12"
                android:background="#33FFFFFF"
                android:gravity="center_vertical"
                android:minHeight="@dimen/vs_60"
                android:paddingLeft="@dimen/vs_10"
                android:paddingTop="@dimen/vs_8"
                android:paddingRight="@dimen/vs_10"
                android:paddingBottom="@dimen/vs_8"
                android:text="状态：等待输入地址后点确定"
                android:textColor="@color/color_CC000000"
                android:textSize="@dimen/ts_22" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_15"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/inputSubmit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="@dimen/vs_10"
                    android:text="确定"
                    android:textColor="@color/color_FFFFFF"
                    android:textSize="@dimen/ts_22" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
